NODE_ENV=production
LOG_LEVEL=info

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hana
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DATABASE=hana

REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
QDRANT_MEMORY_COLLECTION=hana_memory_facts
QDRANT_CHARACTER_COLLECTION=hana_character_profiles
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-neo4j-password
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=hana
CLICKHOUSE_PASSWORD=change-this-clickhouse-password

REDPANDA_BROKERS=redpanda:9092
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_POSTGRES_PASSWORD=change-this-temporal-password

XAI_API_KEY=replace-with-xai-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_DEFAULT_MODEL=grok-4.3
MEDIA_STORAGE_DIR=/var/lib/hana/media
MEDIA_MAX_UPLOAD_BYTES=5242880

RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
RAZORPAYX_ACCOUNT_NUMBER=replace-with-razorpayx-account-number

PHONE_HASH_SECRET=replace-with-at-least-32-random-chars
PHONE_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-key
SESSION_SECRET=replace-with-at-least-32-random-chars
AUTH_COOKIE_NAME=hana_session
AUTH_COOKIE_DOMAIN=.hanachat.site
ADMIN_OTP_BYPASS_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=replace-with-twilio-verify-service-sid

WEB_ORIGIN=https://app.hanachat.site
WEB_ORIGINS=https://app.hanachat.site,https://hanachat.site,https://www.hanachat.site
API_GATEWAY_URL=https://api.hanachat.site
IDENTITY_SERVICE_URL=http://identity-service:4010
RISK_SERVICE_URL=http://risk-service:4020
CHAT_ORCHESTRATOR_URL=http://chat-orchestrator:4030
MEMORY_SERVICE_URL=http://memory-service:4040
RETRIEVAL_SERVICE_URL=http://retrieval-service:4050
GRAPH_SERVICE_URL=http://graph-service:4060
MODERATION_SERVICE_URL=http://moderation-service:4070
BILLING_SERVICE_URL=http://billing-service:4080
CREATOR_SERVICE_URL=http://creator-service:4090
NOTIFICATION_SERVICE_URL=http://notification-service:4100
BATCH_ORCHESTRATOR_URL=http://batch-orchestrator:4110
WORKER_SERVICE_URL=http://worker-service:4120
API_GATEWAY_PORT=4000
IDENTITY_SERVICE_PORT=4010
RISK_SERVICE_PORT=4020
CHAT_ORCHESTRATOR_PORT=4030
MEMORY_SERVICE_PORT=4040
RETRIEVAL_SERVICE_PORT=4050
GRAPH_SERVICE_PORT=4060
MODERATION_SERVICE_PORT=4070
BILLING_SERVICE_PORT=4080
CREATOR_SERVICE_PORT=4090
NOTIFICATION_SERVICE_PORT=4100
BATCH_ORCHESTRATOR_PORT=4110
WORKER_SERVICE_PORT=4120
CREATOR_PAID_CHARACTER_TRIAL_MESSAGES=30

# Playground/public web edge. Keep the raw IP reachable, but use the domain as canonical.
VPS_PUBLIC_IP=18.61.174.6
PUBLIC_WEB_URL=https://hanachat.site
WEB_PORT=3000
CERTBOT_WEBROOT_PATH=/opt/hana-chat/shared/certbot-webroot
LETSENCRYPT_PATH=/opt/hana-chat/shared/letsencrypt
CERTBOT_IMAGE=certbot/certbot:latest

# These power canonical URLs, app redirects, Open Graph, sitemap, robots, and llms.txt.
NEXT_PUBLIC_SITE_URL=https://hanachat.site
NEXT_PUBLIC_APP_URL=https://app.hanachat.site
ACME_EMAIL=support@hanachat.site
